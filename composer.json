{
  "name": "llmesh/openai",
  "description": "OpenAI provider for LLMesh AI library",
  "type": "library",
  "license": "MIT",
  "repositories": [
    {
      "type": "path",
      "url": "../llmesh"
    }
  ],
  "require": {
    "php": "^8.1",
    "llmesh/core": "dev-main || ^0.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "LLMesh\\OpenAI\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LLMesh\\OpenAI\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  }
}
